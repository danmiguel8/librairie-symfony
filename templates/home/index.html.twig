{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<div class="container my-5">

    {% if app.user %}

        {# --- VERSION ACTUELLE (utilisateur connecté) --- #}

        <!-- HERO -->
        <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
            <div class="container-fluid py-5">
                <h1 class="display-5 fw-bold">Bienvenue sur votre bibliothèque</h1>
                <p class="col-md-8 fs-5 mt-3">
                    Gérez vos livres, vos auteurs, vos catégories et votre stock en toute simplicité.
                </p>
                <a href="{{ path('app_book_index') }}" class="btn btn-primary btn-lg mt-3">
                    Voir le catalogue
                </a>
                <a href="{{ path('app_book_new') }}" class="btn btn-success btn-lg mt-3 ms-2">
                    Ajouter un livre
                </a>
            </div>
        </div>

        <!-- SECTIONS -->
        <div class="row text-center mt-5">

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm p-4 h-100">
                    <i class="bi bi-book-half display-4 text-primary mb-3"></i>
                    <h4>Catalogue</h4>
                    <p class="text-muted">Consultez tous les livres disponibles.</p>
                    <a href="{{ path('app_book_index') }}" class="btn btn-outline-primary">
                        Accéder
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm p-4 h-100">
                    <i class="bi bi-plus-circle display-4 text-success mb-3"></i>
                    <h4>Ajouter un livre</h4>
                    <p class="text-muted">Ajoutez un nouveau livre à votre collection.</p>
                    <a href="{{ path('app_book_new') }}" class="btn btn-outline-success">
                        Ajouter
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm p-4 h-100">
                    <i class="bi bi-people display-4 text-warning mb-3"></i>
                    <h4>Utilisateurs</h4>
                    <p class="text-muted">Gérez les utilisateurs de la bibliothèque.</p>
                    <a href="{{ path('admin_user_index') }}" class="btn btn-outline-warning">
                        Accéder
                    </a>
                </div>
            </div>

        </div>

    {% else %}

        {# --- VERSION VISITEUR NON CONNECTÉ --- #}

        <div class="p-5 mb-4 bg-light rounded-3 shadow-sm text-center">
            <h1 class="display-5 fw-bold">Bienvenue dans la bibliothèque 📚</h1>
            <p class="fs-5 mt-3">
                Découvrez notre catalogue et créez un compte pour réserver vos livres.
            </p>

            <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg mt-3">
                Se connecter
            </a>
            <a href="{{ path('app_register') }}" class="btn btn-outline-primary btn-lg mt-3 ms-2">
                Créer un compte
            </a>
        </div>

        <div class="row text-center mt-5">

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm p-4 h-100">
                    <i class="bi bi-book display-4 text-primary mb-3"></i>
                    <h4>Catalogue</h4>
                    <p class="text-muted">Parcourez tous les livres disponibles.</p>
                    <a href="{{ path('app_book_index') }}" class="btn btn-outline-primary">
                        Explorer
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm p-4 h-100">
                    <i class="bi bi-box-arrow-in-right display-4 text-success mb-3"></i>
                    <h4>Connexion</h4>
                    <p class="text-muted">Accédez à votre espace personnel.</p>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-success">
                        Se connecter
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm p-4 h-100">
                    <i class="bi bi-person-plus display-4 text-warning mb-3"></i>
                    <h4>Créer un compte</h4>
                    <p class="text-muted">Rejoignez la bibliothèque en quelques secondes.</p>
                    <a href="{{ path('app_register') }}" class="btn btn-outline-warning">
                        S'inscrire
                    </a>
                </div>
            </div>

        </div>

    {% endif %}

</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
{% endblock %}
