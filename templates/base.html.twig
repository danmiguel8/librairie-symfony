<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}BiblioConnect{% endblock %}</title>

    <link rel="icon" href="data:image/svg+xml,
        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 128 128'>
            <text y='1.2em' font-size='96'>📚</text>
        </svg>">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .navbar-brand { font-weight: 600; letter-spacing: .5px; }
        footer a { text-decoration: none; }
        footer a:hover { text-decoration: underline; }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body class="bg-light d-flex flex-column min-vh-100">

<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
        <div class="container">

            <a class="navbar-brand" href="{{ path('app_home') }}">BiblioConnect</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Catalogue</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Événements</a>
                    </li>

                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="#">Espace bibliothécaire</a>
                        </li>
                    {% endif %}
                </ul>

                <form class="d-flex me-3" action="#" method="GET">
                    <input class="form-control me-2" name="q" type="search" placeholder="Rechercher un livre…">
                    <button class="btn btn-outline-success">OK</button>
                </form>

                {% if app.user %}
                    <a class="btn btn-outline-light me-2" href="#">Mon compte</a>
                    <a class="btn btn-danger" href="/logout">Déconnexion</a>
                {% else %}
                    <a class="btn btn-outline-light me-2" href="{{ path('app_login') }}">Connexion</a>
                    <a class="btn btn-success" href="{{ path('app_register') }}">Inscription</a>
                {% endif %}

            </div>
        </div>
    </nav>
</header>

<main class="container py-4 flex-grow-1">
    {% block body %}{% endblock %}
</main>


<footer class="bg-dark text-white py-4">

    <div class="container">
        <div class="row text-center">

            <div class="col-md-4 mb-3">
                <h6>Informations</h6>
                <a class="text-white d-block" href="#">Mentions légales</a>
                <a class="text-white d-block" href="#">Politique de confidentialité</a>
            </div>

            <div class="col-md-4 mb-3">
                <h6>Liens utiles</h6>
                <a class="text-white d-block" href="#">Catalogue</a>
                <a class="text-white d-block" href="#">Événements</a>
                <a class="text-white d-block" href="#">FAQ</a>
            </div>

            <div class="col-md-4 mb-3">
                <h6>Contact</h6>
                <a class="text-white d-block" href="#">Nous contacter</a>
                <a class="text-white d-block" href="#">À propos</a>
            </div>

        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>