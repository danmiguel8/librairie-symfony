{% extends 'base.html.twig' %}

{% block title %}Modifier le livre{% endblock %}

{% block body %}
<div class="container my-5">

    <h1 class="text-center mb-4">Modifier le livre</h1>

    <div class="card shadow-sm p-4 mx-auto" style="max-width: 700px;">

        {{ include('book/_form.html.twig', {
            button_label: 'Mettre à jour'
        }) }}

        <div class="d-flex justify-content-between mt-3">
            <a href="{{ path('app_book_index') }}" class="btn btn-secondary">
                ← Retour au catalogue
            </a>

            {{ include('book/_delete_form.html.twig') }}
        </div>

    </div>

</div>
{% endblock %}
