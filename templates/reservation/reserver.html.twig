{% extends 'base.html.twig' %}

{% block title %}Réserver un livre{% endblock %}

{% block body %}
<div class="container my-5">

    <h1 class="mb-4">Réserver : {{ book.title }}</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title">{{ book.title }}</h5>
            <p class="text-muted">Auteur : {{ book.author.firstName }} {{ book.author.lastName }}</p>
            <p>{{ book.description }}</p>
        </div>
    </div>

 <div class="card shadow-sm p-4">
    <h4 class="mb-3">Informations de réservation</h4>

    {{ form_start(form, { attr: { class: 'row g-4' } }) }}

        <div class="col-md-6">
            {{ form_label(form.dateDebut, 'Date de début', { label_attr: { class: 'form-label fw-bold' } }) }}
            {{ form_widget(form.dateDebut, { attr: { class: 'form-control' } }) }}
            {{ form_errors(form.dateDebut) }}
        </div>

        <div style="display:none;">
            {{ form_row(form.client) }}
        </div>

        <div class="col-md-6">
            {{ form_label(form.dateFin, 'Date de fin', { label_attr: { class: 'form-label fw-bold' } }) }}
            {{ form_widget(form.dateFin, { attr: { class: 'form-control' } }) }}
            {{ form_errors(form.dateFin) }}
        </div>

        <div class="col-md-12">
            {{ form_label(form.books, 'Livres', { label_attr: { class: 'form-label fw-bold' } }) }}
            {{ form_widget(form.books, { attr: { class: 'form-select', multiple: true, size: 5 } }) }}
            {{ form_errors(form.books) }}
        </div>

        <div class="col-12 mt-3">
            <button class="btn btn-primary w-100 py-2">
                Valider la réservation
            </button>
        </div>

    {{ form_end(form) }}
</div>


    <a href="{{ path('app_profile_reservation') }}" class="btn btn-secondary mt-4">
        ← Retour à la liste des réservations
    </a>

</div>
{% endblock %}
