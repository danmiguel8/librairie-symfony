{% extends 'base.html.twig' %}

{% block title %}Historique des réservations{% endblock %}

{% block body %}
<div class="container my-5">

    <h1 class="mb-4">Réservations en attente</h1>

    {% if reservations is empty %}
        <div class="alert alert-info">
            Aucune réservation en attente pour le moment.
        </div>
    {% else %}

        <table class="table table-striped table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Client</th>
                    <th>Livres & Quantités</th>
                    <th>Date début</th>
                    <th>Date fin</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                {% for reservation in reservations %}
                    <tr>
                        <td>{{ reservation.id }}</td>

                        <td>
                            <strong>
                                {{ reservation.client.firstName }} {{ reservation.client.lastName }}
                            </strong>
                        </td>

                        <td>
                            {% for book in reservation.books %}
                                <span class="badge bg-primary">{{ book.title }}</span>
                                <span class="badge bg-secondary pl-2"> - Quantité en stock : {{ book.quantite }}</span>
                            {% endfor %}
                        </td>

                        <td>{{ reservation.dateDebut|date('d/m/Y') }}</td>
                        <td>{{ reservation.dateFin|date('d/m/Y') }}</td>

                        <td>
                            <a href="{{ path('app_reservation_action', { id: reservation.id, action: 'validate' }) }}"
                               class="btn btn-sm btn-outline-success">
                                Valider
                            </a>
                            <a href="{{ path('app_reservation_action', { id: reservation.id, action: 'cancel' }) }}"
                               class="btn btn-sm btn-outline-danger">
                                Rejéter
                            </a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

    {% endif %}

</div>
{% endblock %}
